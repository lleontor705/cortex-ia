#!/usr/bin/env bash
set -e

echo "=== cortex-ia pre-commit checks ==="

# 1. Format check
echo "[1/4] Checking formatting..."
UNFORMATTED=$(gofmt -l . 2>/dev/null | grep -v vendor/ || true)
if [ -n "$UNFORMATTED" ]; then
    echo "FAIL: Unformatted files:"
    echo "$UNFORMATTED"
    echo "Run: gofmt -s -w ."
    exit 1
fi
echo "  ✓ Formatting OK"

# 2. Vet
echo "[2/4] Running go vet..."
go vet ./...
echo "  ✓ Vet OK"

# 3. Security scan (optional)
echo "[3/4] Security scan..."
if command -v govulncheck &>/dev/null; then
    govulncheck ./... 2>&1 || true
    echo "  ✓ Security scan done"
else
    echo "  ~ govulncheck not installed (skipping)"
fi

# 4. Tests
echo "[4/4] Running tests..."
go test ./... -count=1 -timeout 120s
echo "  ✓ Tests OK"

echo ""
echo "=== All pre-commit checks passed ==="
